<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_salesperson_location_log_list" model="ir.ui.view">
        <field name="name">salesperson.location.log.list</field>
        <field name="model">salesperson.location.log</field>
        <field name="arch" type="xml">
            <list string="Location History">
                <field name="tracked_at" width="180"/>
                <field name="user_id" width="150"/>
                <field name="latitude"/>
                <field name="longitude"/>
                <field name="accuracy" optional="hide"/>
                <field name="speed" optional="hide"/>
                <field name="location_name"/>
                <field name="openstreetmap_url" widget="url" string="Map"/>
            </list>
        </field>
    </record>

    <record id="action_salesperson_location_log" model="ir.actions.act_window">
        <field name="name">Location History</field>
        <field name="res_model">salesperson.location.log</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>