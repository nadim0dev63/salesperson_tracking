<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_salesperson_location_backup_list" model="ir.ui.view">
        <field name="name">salesperson.location.backup.list</field>
        <field name="model">salesperson.location.backup</field>
        <field name="arch" type="xml">
            <list string="Location Backups">
                <field name="backup_date"/>
                <field name="user_id"/>
                <field name="record_count"/>
                <field name="created_at"/>
                <field name="expires_at"/>
                <button name="action_download_csv" string="Download CSV" type="object" class="btn-secondary"/>
            </list>
        </field>
    </record>

    <record id="action_salesperson_location_backup" model="ir.actions.act_window">
        <field name="name">Location Backups</field>
        <field name="res_model">salesperson.location.backup</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>