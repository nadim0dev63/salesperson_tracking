<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.inherit.salesperson</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="15"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <!-- Add at the end of all settings -->
            <xpath expr="//setting[.//field[@name='show_effect']]" position="after">
                <setting string="Keep Location Data (days)" help="Number of days to keep recent location data">
                    <field name="location_keep_days"/>
                </setting>
                <setting string="Backup Retention (days)" 
                    help="Number of days to keep backups">
                    <field name="backup_retention_days"/>
                </setting>
                <setting string="Geofence Radius (meters)" 
                    help="Radius for auto check-in/out detection">
                    <field name="geofence_radius_meters"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>