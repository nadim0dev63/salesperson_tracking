<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_salesperson_visit_plan" model="ir.sequence">
            <field name="name">Visit Plan Sequence</field>
            <field name="code">salesperson.visit.plan</field>
            <field name="prefix">VP/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_salesperson_checkin" model="ir.sequence">
            <field name="name">Check-In Sequence</field>
            <field name="code">salesperson.checkin</field>
            <field name="prefix">CI/%(day)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>