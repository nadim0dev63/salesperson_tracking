<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="cron_location_backup" model="ir.cron">
            <field name="name">Location Data Backup &amp; Purge</field>
            <field name="model_id" ref="zencore_salesperson_tracking.model_salesperson_location_backup"/>
            <field name="state">code</field>
            <field name="code">model.action_run_backup_policy()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="(DateTime.now()).strftime('%Y-%m-%d 02:00:00')"/>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>