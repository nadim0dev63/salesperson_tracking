<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_visit_plan" model="ir.actions.report">
        <field name="name">Visit Plan Report</field>
        <field name="model">salesperson.visit.plan</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">zencore_salesperson_tracking.report_visit_plan</field>
        <field name="binding_model_id" ref="model_salesperson_visit_plan"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_visit_plan">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="plan">
                <t t-call="web.external_layout">
                    <div class="page">

                        <style>
                            /* ── Reset ── */
                            * { box-sizing: border-box; margin: 0; padding: 0; }

                            /* ── Report Header Banner ── */
                            .rpt-header {
                                background: linear-gradient(135deg, #134e2a 0%, #16a34a 100%);
                                border-radius: 10px;
                                padding: 24px 28px;
                                margin-bottom: 22px;
                                color: #fff;
                            }
                            .rpt-header-top {
                                display: flex;
                                justify-content: space-between;
                                align-items: flex-start;
                            }
                            .rpt-title {
                                font-size: 22px;
                                font-weight: 700;
                                letter-spacing: 0.5px;
                                margin-bottom: 4px;
                            }
                            .rpt-subtitle {
                                font-size: 11px;
                                opacity: 0.75;
                                text-transform: uppercase;
                                letter-spacing: 1.2px;
                            }
                            .rpt-ref {
                                background: rgba(255,255,255,0.18);
                                border: 1px solid rgba(255,255,255,0.35);
                                border-radius: 20px;
                                padding: 5px 16px;
                                font-size: 12px;
                                font-weight: 700;
                                letter-spacing: 0.5px;
                            }
                            .rpt-meta-row {
                                display: flex;
                                gap: 28px;
                                margin-top: 16px;
                                border-top: 1px solid rgba(255,255,255,0.2);
                                padding-top: 14px;
                            }
                            .rpt-meta-item label {
                                display: block;
                                font-size: 9px;
                                text-transform: uppercase;
                                letter-spacing: 1px;
                                opacity: 0.65;
                                margin-bottom: 2px;
                            }
                            .rpt-meta-item span {
                                font-size: 13px;
                                font-weight: 600;
                            }

                            /* ── KPI Cards ── */
                            .kpi-row {
                                display: flex;
                                gap: 12px;
                                margin-bottom: 22px;
                            }
                            .kpi-card {
                                flex: 1;
                                border-radius: 8px;
                                padding: 14px 16px;
                                text-align: center;
                                border: 1px solid #e2e8f0;
                            }
                            .kpi-card.green  { background: #f0fdf4; border-color: #86efac; }
                            .kpi-card.blue   { background: #eff6ff; border-color: #93c5fd; }
                            .kpi-card.amber  { background: #fffbeb; border-color: #fcd34d; }
                            .kpi-card.slate  { background: #f8fafc; border-color: #cbd5e1; }
                            .kpi-num {
                                font-size: 26px;
                                font-weight: 800;
                                line-height: 1;
                                margin-bottom: 4px;
                            }
                            .kpi-card.green .kpi-num { color: #16a34a; }
                            .kpi-card.blue  .kpi-num { color: #2563eb; }
                            .kpi-card.amber .kpi-num { color: #d97706; }
                            .kpi-card.slate .kpi-num { color: #475569; }
                            .kpi-label {
                                font-size: 9.5px;
                                font-weight: 600;
                                text-transform: uppercase;
                                letter-spacing: 0.8px;
                                color: #64748b;
                            }

                            /* ── Purpose callout ── */
                            .purpose-box {
                                background: #f0fdf4;
                                border-left: 4px solid #16a34a;
                                border-radius: 0 8px 8px 0;
                                padding: 10px 16px;
                                margin-bottom: 22px;
                                font-size: 12px;
                                color: #166534;
                            }
                            .purpose-box strong {
                                display: block;
                                font-size: 9px;
                                text-transform: uppercase;
                                letter-spacing: 1px;
                                color: #16a34a;
                                margin-bottom: 3px;
                            }

                            /* ── Section Headers ── */
                            .section-header {
                                display: flex;
                                align-items: center;
                                gap: 8px;
                                margin: 20px 0 10px 0;
                            }
                            .section-bar {
                                width: 4px;
                                height: 18px;
                                border-radius: 2px;
                                background: linear-gradient(180deg, #16a34a, #134e2a);
                            }
                            .section-title {
                                font-size: 13px;
                                font-weight: 700;
                                color: #134e2a;
                                text-transform: uppercase;
                                letter-spacing: 0.6px;
                            }
                            .section-line {
                                flex: 1;
                                height: 1px;
                                background: #e2e8f0;
                            }

                            /* ── Tables ── */
                            .rpt-table {
                                width: 100%;
                                border-collapse: collapse;
                                font-size: 11.5px;
                                border-radius: 8px;
                                overflow: hidden;
                                border: 1px solid #e2e8f0;
                                margin-bottom: 6px;
                            }
                            .rpt-table thead tr {
                                background: #134e2a;
                                color: #fff;
                            }
                            .rpt-table thead th {
                                padding: 9px 12px;
                                font-size: 10px;
                                font-weight: 600;
                                text-transform: uppercase;
                                letter-spacing: 0.7px;
                                text-align: left;
                            }
                            .rpt-table thead th.right { text-align: right; }
                            .rpt-table thead th.center { text-align: center; }
                            .rpt-table tbody tr:nth-child(even) { background: #f8fafc; }
                            .rpt-table tbody tr:nth-child(odd)  { background: #ffffff; }
                            .rpt-table tbody tr:last-child td { border-bottom: none; }
                            .rpt-table td {
                                padding: 8px 12px;
                                border-bottom: 1px solid #f1f5f9;
                                color: #334155;
                                vertical-align: middle;
                            }
                            .rpt-table td.right  { text-align: right; font-variant-numeric: tabular-nums; }
                            .rpt-table td.center { text-align: center; }
                            .rpt-table td.label  { font-weight: 600; color: #134e2a; }
                            .rpt-table tfoot tr {
                                background: #f0fdf4;
                                border-top: 2px solid #86efac;
                            }
                            .rpt-table tfoot td {
                                padding: 9px 12px;
                                font-weight: 700;
                                color: #134e2a;
                                border-bottom: none;
                            }

                            /* ── Route arrow chip ── */
                            .route-chip {
                                display: inline-flex;
                                align-items: center;
                                gap: 4px;
                                background: #eff6ff;
                                border: 1px solid #bfdbfe;
                                border-radius: 4px;
                                padding: 2px 8px;
                                font-size: 10.5px;
                                color: #1d4ed8;
                            }
                            .route-arrow { color: #60a5fa; font-weight: 700; }

                            /* ── Pill badges ── */
                            .pill {
                                display: inline-block;
                                border-radius: 4px;
                                padding: 1px 7px;
                                font-size: 10px;
                                font-weight: 700;
                            }
                            .pill.green  { background: #f0fdf4; color: #15803d; }
                            .pill.blue   { background: #eff6ff; color: #1d4ed8; }
                            .pill.amber  { background: #fffbeb; color: #b45309; }

                            /* ── Two-col layout ── */
                            .two-col { display: flex; gap: 16px; margin-bottom: 6px; }
                            .two-col .col { flex: 1; }

                            /* ── Signature block ── */
                            .sig-row {
                                display: flex;
                                gap: 40px;
                                margin-top: 32px;
                                padding-top: 16px;
                                border-top: 1px solid #e2e8f0;
                            }
                            .sig-block { flex: 1; }
                            .sig-line {
                                border-bottom: 1px solid #334155;
                                height: 36px;
                                margin-bottom: 6px;
                            }
                            .sig-label {
                                font-size: 9px;
                                text-transform: uppercase;
                                letter-spacing: 0.8px;
                                color: #94a3b8;
                            }

                            /* ── Footer ── */
                            .rpt-footer {
                                margin-top: 24px;
                                border-top: 1px solid #e2e8f0;
                                padding-top: 10px;
                                font-size: 9px;
                                color: #94a3b8;
                                text-align: center;
                            }
                        </style>

                        <!-- ══ HEADER BANNER ══ -->
                        <div class="rpt-header">
                            <div class="rpt-header-top">
                                <div>
                                    <div class="rpt-title">Visit Plan Report</div>
                                    <div class="rpt-subtitle">ZenCore Salesperson Tracking</div>
                                </div>
                                <div class="rpt-ref"><t t-esc="plan.name"/></div>
                            </div>
                            <div class="rpt-meta-row">
                                <div class="rpt-meta-item">
                                    <label>Salesperson</label>
                                    <span><t t-esc="plan.user_id.name"/></span>
                                </div>
                                <div class="rpt-meta-item">
                                    <label>Visit Date</label>
                                    <span><t t-esc="plan.visit_date"/></span>
                                </div>
                                <div class="rpt-meta-item">
                                    <label>Total Stops</label>
                                    <span><t t-esc="plan.total_visits"/></span>
                                </div>
                                <div class="rpt-meta-item">
                                    <label>Total Budget</label>
                                    <span><t t-esc="plan.total_cost"/></span>
                                </div>
                            </div>
                        </div>

                        <!-- ══ PURPOSE ══ -->
                        <t t-if="plan.purpose">
                            <div class="purpose-box">
                                <strong>Purpose</strong>
                                <t t-esc="plan.purpose"/>
                            </div>
                        </t>

                        <!-- ══ KPI CARDS ══ -->
                        <div class="kpi-row">
                            <div class="kpi-card blue">
                                <div class="kpi-num"><t t-esc="plan.total_visits"/></div>
                                <div class="kpi-label">Total Stops</div>
                            </div>
                            <div class="kpi-card amber">
                                <div class="kpi-num"><t t-esc="plan.transport_cost"/></div>
                                <div class="kpi-label">Transport</div>
                            </div>
                            <div class="kpi-card green">
                                <div class="kpi-num"><t t-esc="plan.food_cost"/></div>
                                <div class="kpi-label">Food</div>
                            </div>
                            <div class="kpi-card slate">
                                <div class="kpi-num"><t t-esc="plan.other_cost"/></div>
                                <div class="kpi-label">Other</div>
                            </div>
                            <div class="kpi-card blue">
                                <div class="kpi-num"><t t-esc="plan.total_cost"/></div>
                                <div class="kpi-label">Total Budget</div>
                            </div>
                        </div>

                        <!-- ══ EXPENSES CLAIM ══ -->
                        <div class="section-header">
                            <div class="section-bar"/>
                            <div class="section-title">Expenses Claim</div>
                            <div class="section-line"/>
                        </div>

                        <table class="rpt-table">
                            <thead>
                                <tr>
                                    <th>Category</th>
                                    <th class="right">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="label">Transport</td>
                                    <td class="right"><t t-esc="plan.transport_cost"/></td>
                                </tr>
                                <tr>
                                    <td class="label">Food</td>
                                    <td class="right"><t t-esc="plan.food_cost"/></td>
                                </tr>
                                <tr>
                                    <td class="label">Other</td>
                                    <td class="right"><t t-esc="plan.other_cost"/></td>
                                </tr>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td>Total Claim</td>
                                    <td class="right"><t t-esc="plan.total_cost"/></td>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- ══ TARGET LINES ══ -->
                        <div class="section-header">
                            <div class="section-bar"/>
                            <div class="section-title">Target Visit Lines</div>
                            <div class="section-line"/>
                        </div>

                        <table class="rpt-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Customer(s)</th>
                                    <th>Route</th>
                                    <th class="center">Est. Time</th>
                                    <th class="right">Est. KM</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="plan.target_line_ids" t-as="line">
                                    <tr>
                                        <td style="color:#94a3b8; width:28px;">
                                            <t t-esc="line_index + 1"/>
                                        </td>
                                        <td style="font-weight:600;">
                                            <t t-esc="', '.join(line.customer_ids.mapped('name'))"/>
                                        </td>
                                        <td>
                                            <span class="route-chip">
                                                <t t-esc="line.from_location"/>
                                                <span class="route-arrow">→</span>
                                                <t t-esc="line.to_location"/>
                                            </span>
                                        </td>
                                        <td class="center">
                                            <span class="pill amber">
                                                <t t-esc="line.expected_time_minutes"/> min
                                            </span>
                                        </td>
                                        <td class="right">
                                            <span class="pill blue">
                                                <t t-esc="line.expected_km"/> km
                                            </span>
                                        </td>
                                    </tr>
                                </t>
                                <t t-if="not plan.target_line_ids">
                                    <tr>
                                        <td colspan="5" style="text-align:center; color:#94a3b8; padding:20px;">
                                            No target lines added yet.
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- ══ SIGNATURE BLOCK ══ -->
                        <div class="sig-row">
                            <div class="sig-block">
                                <div class="sig-line"/>
                                <div class="sig-label">Salesperson Signature</div>
                            </div>
                            <div class="sig-block">
                                <div class="sig-line"/>
                                <div class="sig-label">Manager Approval</div>
                            </div>
                            <div class="sig-block">
                                <div class="sig-line"/>
                                <div class="sig-label">Date</div>
                            </div>
                        </div>

                        <!-- ══ FOOTER ══ -->
                        <div class="rpt-footer">
                            Generated by ZenCore Salesperson Tracking ·
                            <t t-esc="plan.user_id.company_id.name"/>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>