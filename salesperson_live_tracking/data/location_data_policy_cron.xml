<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Scheduled Action: Location Log Data Policy
         Runs every 7 days.
         • Backs up location logs older than 7 days into
           salesperson.location.backup (JSON payload per tracker/day).
         • Deletes the live log records that were just backed up.
         • Purges backup records whose 7-day retention window has expired.
    ============================================================ -->
    <record id="ir_cron_location_data_policy" model="ir.cron">
        <field name="name">Salesperson Location: 7-Day Data Policy (Backup + Auto-Delete)</field>
        <field name="model_id" ref="model_salesperson_location_backup"/>
        <field name="state">code</field>
        <field name="code">model.action_run_data_policy()</field>
        <field name="interval_number">7</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
        <field name="user_id" ref="base.user_root"/>
    </record>

</odoo>
