<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mail_template_route_deviation_alert" model="mail.template">
        <field name="name">Salesperson Route Deviation Alert</field>
        <field name="model_id" ref="model_salesperson_tracker"/>
        <field name="subject">⚠️ Route Deviation Alert: {{ object.user_id.name }}</field>
        <field name="body_html"><![CDATA[
<p>Dear Manager,</p>
<p><strong>{{ object.user_id.name }}</strong> appears to have deviated from their assigned route.</p>
<ul>
    <li><strong>Last Known Location:</strong> {{ object.location_name or 'Unknown' }}</li>
    <li><strong>Last Update:</strong> {{ object.last_seen }}</li>
    <li><strong>Status:</strong> {{ object.tracking_status_label }}</li>
</ul>
<p>Please check the live tracking dashboard for details.</p>
        ]]></field>
        <field name="auto_delete" eval="True"/>
    </record>

    <record id="ir_sequence_salesperson_checkin" model="ir.sequence">
        <field name="name">Salesperson Check-In Reference</field>
        <field name="code">salesperson.checkin</field>
        <field name="prefix">CHK/%(year)s/%(month)s/</field>
        <field name="padding">4</field>
    </record>
</odoo>
