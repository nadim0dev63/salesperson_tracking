<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── List view ─────────────────────────────────────────────── -->
    <record id="view_salesperson_location_backup_list" model="ir.ui.view">
        <field name="name">salesperson.location.backup.list</field>
        <field name="model">salesperson.location.backup</field>
        <field name="arch" type="xml">
            <list string="Location Backups" create="false">
                <field name="backup_date"/>
                <field name="tracker_id"/>
                <field name="user_id"/>
                <field name="record_count"/>
                <field name="created_at"/>
                <field name="retention_expires_at"/>
                <button name="action_download_csv"
                        string="Download CSV"
                        type="object"
                        icon="fa-download"/>
                <button name="action_restore_backup"
                        string="Restore to Live Log"
                        type="object"
                        icon="fa-upload"
                        groups="salesperson_live_tracking.group_salesperson_tracking_manager"/>
            </list>
        </field>
    </record>

    <!-- ── Form view ─────────────────────────────────────────────── -->
    <record id="view_salesperson_location_backup_form" model="ir.ui.view">
        <field name="name">salesperson.location.backup.form</field>
        <field name="model">salesperson.location.backup</field>
        <field name="arch" type="xml">
            <form string="Location Backup" create="false">
                <sheet>
                    <group>
                        <group string="Snapshot Info">
                            <field name="tracker_id" readonly="1"/>
                            <field name="user_id"    readonly="1"/>
                            <field name="backup_date" readonly="1"/>
                            <field name="record_count" readonly="1"/>
                        </group>
                        <group string="Retention">
                            <field name="created_at"           readonly="1"/>
                            <field name="retention_expires_at" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="JSON Payload">
                            <field name="payload" readonly="1" widget="text"
                                   options="{'rows': 20}"/>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="action_download_csv"
                            string="Download CSV"
                            type="object"
                            class="btn-primary"/>
                    <button name="action_restore_backup"
                            string="Restore to Live Log"
                            type="object"
                            class="btn-secondary"
                            groups="salesperson_live_tracking.group_salesperson_tracking_manager"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ── Action ────────────────────────────────────────────────── -->
    <record id="action_salesperson_location_backup" model="ir.actions.act_window">
        <field name="name">Location Backups</field>
        <field name="res_model">salesperson.location.backup</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
